{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: uvicorn",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "uvicorn",
        "app.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "options": {
        "cwd": "",
        "env": {
          "PYTHONPATH": ""
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "test: pytest",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "pytest",
        "-q"
      ],
      "options": {
        "cwd": ""
      },
      "group": "test"
    }
  ]
}
